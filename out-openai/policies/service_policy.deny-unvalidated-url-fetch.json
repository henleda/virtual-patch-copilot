{
  "algo": "FIRST_MATCH",
  "any_server": {},
  "rule_list": {
    "rules": [
      {
        "metadata": {
          "name": "deny-unvalidated-url-fetch"
        },
        "spec": {
          "action": "DENY",
          "any_client": {},
          "path": {
            "prefix_values": [
              "/avatar"
            ]
          },
          "http_method": {
            "methods": [
              "GET",
              "POST"
            ]
          },
          "query_params": [
            {
              "item": {
                "regex_values": [
                  "http://169\\.254\\.169\\.254/latest/meta-data/"
                ]
              }
            }
          ]
        }
      },
      {
        "metadata": {
          "name": "allow-all"
        },
        "spec": {
          "action": "ALLOW",
          "any_client": {},
          "path": {
            "prefix_values": [
              "/"
            ]
          },
          "http_method": {
            "methods": [
              "GET",
              "POST",
              "PUT",
              "DELETE",
              "PATCH",
              "HEAD",
              "OPTIONS"
            ]
          }
        }
      }
    ]
  }
}