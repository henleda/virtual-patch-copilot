# Copy to .env and fill in. The brain (scan) only needs the model provider key(s) you
# reference in config/agents.yaml. XC_* and GITHUB_* are for the deploy/apply increment.

# --- Model providers (set the one(s) you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Local models via Ollama:
# OLLAMA_API_BASE=http://localhost:11434

# --- F5 Distributed Cloud (deploy/apply step) ---
XC_TENANT=            # e.g. yourtenant
XC_API_URL=          # e.g. https://yourtenant.console.ves.volterra.io/api
XC_API_TOKEN=        # scoped, least-privilege; never commit
XC_NAMESPACE=        # target namespace

# --- GitHub (remediation PRs) ---
GITHUB_TOKEN=        # repo-scoped PAT for opening code-fix PRs
