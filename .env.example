# Copy to .env and fill in. `scan` only needs the model provider key(s) you reference in
# config/agents.yaml — XC_* and GITHUB_TOKEN are only for the live apply / PR steps. Never commit .env.

# --- Model providers (set the one(s) you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Local models via Ollama:
# OLLAMA_API_BASE=http://localhost:11434

# --- F5 Distributed Cloud (live apply/validate/retire) ---
XC_API_URL=          # e.g. https://yourtenant.console.ves.volterra.io/api
XC_API_TOKEN=        # scoped, least-privilege; never commit
XC_NAMESPACE=        # target namespace
# XC_DASHBOARD_URL=  # optional deep link to your XC security dashboard (else derived from XC_API_URL)

# --- GitHub (code-fix PRs) ---
GITHUB_TOKEN=        # repo-scoped PAT for opening PRs (or use `gh auth login`)

# --- Optional tuning (sensible defaults; override to taste) ---
# CHANGE_CONTROL_DAYS=25               # the "vs N-day change control" contrast in the hero/report
# VPCOPILOT_PROTECTED_LBS=nimbus-www   # comma-separated LBs that refuse mutation without an override
# VPCOPILOT_REFINE_ATTEMPTS=3          # max self-heal attempts when a policy doesn't block the exploit
# VPCOPILOT_REQUIRE_PROBE=1            # fail-closed: don't validate a finding that has no derived probe
# Console action defaults (so the UI isn't pinned to one app):
# VPCOPILOT_DEFAULT_LB=your-lb
# VPCOPILOT_DEFAULT_URL=https://your-app.example.com
# VPCOPILOT_DEFAULT_REPO=owner/repo
# VPCOPILOT_DEFAULT_BASE=main
# VPCOPILOT_DEFAULT_PREFIX=
